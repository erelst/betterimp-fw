#!/bin/sh
# .githooks/pre-commit - AI compliance checker for betterimp-fw
# Dipanggil otomatis oleh git commit
# BLOCK > 0 will reject the commit

echo ""
echo "=== betterimp-fw: AI compliance pre-check ==="
echo ""

PASS=0
BLOCK=0
CHANGED_FILES=$(git diff --cached --name-only 2>/dev/null || echo "")

warn() {
    echo "  \342\232\240\357\270\217  $1"
    BLOCK=$((BLOCK + 1))
}

pass() {
    echo "  \342\234\205 $1"
    PASS=$((PASS + 1))
}

# --- 1. STATE.md update check ---
if echo "$CHANGED_FILES" | grep -q "src/"; then
    if ! echo "$CHANGED_FILES" | grep -q "STATE.md"; then
        warn "src/ changed but STATE.md not updated"
    else
        pass "STATE.md updated with src/ changes"
    fi
fi

# --- 2. DOX chain integrity check ---
echo ""
echo "--- DOX Chain Check ---"
for f in $CHANGED_FILES; do
    # Skip deleted files
    test -f "$f" || continue

    dir=$(dirname "$f")
    found_agents=0

    # Traverse up to root looking for AGENTS.md
    while [ "$dir" != "." ]; do
        if [ -f "$dir/AGENTS.md" ]; then
            found_agents=1
            break
        fi
        dir=$(dirname "$dir")
    done

    if [ "$found_agents" -eq 1 ]; then
        pass "DOX chain OK: $f (via $dir/AGENTS.md)"
    else
        # Check root too
        if [ -f "AGENTS.md" ]; then
            pass "DOX chain OK: $f (via root AGENTS.md)"
        else
            warn "No AGENTS.md in ancestry of $f"
        fi
    fi
done

# --- 3. rtk usage check in diff ---
echo ""
echo "--- rtk Usage Check ---"
DIFF=$(git diff --cached 2>/dev/null)
if [ -n "$DIFF" ]; then
    # Scan for command executions without rtk prefix
    # Patterns: shell commands like `command`, sh -c, etc.
    NON_RTK_CMDS=$(echo "$DIFF" | grep -E '^\+\s*(cargo|npm|npx|yarn|pnpm|pip|make|rustc|go|python|node|deno|bun|wasm)' | grep -v 'rtk' | head -5)
    if [ -n "$NON_RTK_CMDS" ]; then
        echo "  \342\232\240\357\270\217  Commands without rtk prefix detected:"
        echo "$NON_RTK_CMDS" | while read -r line; do
            echo "       $line"
        done
        BLOCK=$((BLOCK + 1))
    else
        pass "All commands use rtk prefix"
    fi
else
    pass "No staged diff to scan"
fi

echo ""
echo "=== Result: $PASS passed, $BLOCK blocking ==="
echo ""

if [ "$BLOCK" -gt 0 ] 2>/dev/null; then
    echo ""
    echo "❌ Compliance issues found. Commit BLOCKED."
    echo "   Use 'git commit --no-verify' to bypass (not recommended)"
    exit 1
else
    echo ""
    echo "✅ All compliance checks passed"
    exit 0
fi
